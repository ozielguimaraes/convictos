# Postgres (container existente postgres-latest, porta 5432; database convictos com collation ICU pt-BR)
DATABASE_URL=postgres://convictos:convictos_dev@127.0.0.1:5432/convictos

# Porta da API Express
PORT=3001

# URL pública do app (usada nos links mágicos enviados por e-mail)
APP_URL=http://localhost:5173

# SMTP para envio de OTP/link mágico.
# Sem SMTP configurado, o código e o link são impressos no console do servidor (modo dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Convictos <no-reply@querc.app>"
